<p style="color: green"><%= notice %></p>

<%= render @category %>

<%= link_to "Добавить товар в эту категорию",
            new_product_path(category_id: @category.id),
            class: "button" %>

<h2>Товары в категории</h2>

<% if @category.products.any? %>
  <ul>
    <% @category.products.each do |product| %>
      <li>
        <%= link_to product.name, product_path(product) %>
        — <%= number_to_currency(product.price) %>
      </li>
    <% end %>
  </ul>
<% else %>
  <p>В этой категории пока нет товаров.</p>
<% end %>

<div>
  <%= link_to "Изменить эту категорию", edit_category_path(@category) %> |
  <%= link_to "Назад к списку категорий", categories_path %>

  <%= button_to "Удалить эту категорию", @category, method: :delete %>
</div>
